{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"color": "#1a3628",
					"name": "Brand Green",
					"slug": "brand-green"
				},
				{
					"color": "#ffbd59",
					"name": "Brand Yellow",
					"slug": "brand-yellow"
				},
				{
					"color": "#ffffff",
					"name": "Base White",
					"slug": "base-white"
				},
				{
					"color": "#28523c",
					"name": "Green Hover",
					"slug": "brand-green-hover"
				},
				{
					"color": "#e6a23e",
					"name": "Yellow Hover",
					"slug": "brand-yellow-hover"
				},
				{
					"color": "#1c241f",
					"name": "Text Main",
					"slug": "text-main"
				},
				{
					"color": "#526058",
					"name": "Text Muted",
					"slug": "text-muted"
				},
				{
					"color": "#f0f4f1",
					"name": "Surface Alt",
					"slug": "surface-alt"
				},
				{
					"color": "#c94a4a",
					"name": "UI Danger",
					"slug": "ui-danger"
				}
			]
		},
		"layout": {
			"contentSize": "50rem",
			"wideSize": "62.5rem"
		},
		"spacing": {
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": false,
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"name": "System Font",
					"slug": "system-font"
				},
				{
					"fontFace": [
						{
							"fontFamily": "\"Open Sans\"",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/open-sans/open-sans-400-normal.woff2"
							]
						},
						{
							"fontFamily": "\"Open Sans\"",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/open-sans/open-sans-700-normal.woff2"
							]
						}
					],
					"fontFamily": "\"Open Sans\", sans-serif",
					"name": "Open Sans",
					"slug": "open-sans"
				},
				{
					"fontFace": [
						{
							"fontFamily": "\"PT Serif\"",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/pt-serif/pt-serif-400-normal.woff2"
							]
						},
						{
							"fontFamily": "\"PT Serif\"",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/pt-serif/pt-serif-700-normal.woff2"
							]
						}
					],
					"fontFamily": "\"PT Serif\", serif",
					"name": "PT Serif",
					"slug": "pt-serif"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"size": "1rem",
					"slug": "small"
				},
				{
					"name": "Medium",
					"size": "1.13rem",
					"slug": "medium"
				},
				{
					"name": "Large",
					"size": "1.5rem",
					"slug": "large"
				},
				{
					"name": "Extra Large",
					"size": "2rem",
					"slug": "x-large"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/button": {
				"variations": {
					"outline": {
						"color": {
							"background": "var(--wp--preset--color--brand-green-hover)",
							"text": "var(--wp--preset--color--base-white)"
						}
					}
				}
			},
			"core/heading": {
				"spacing": {
					"margin": {
						"bottom": "0.25em",
						"top": "0.75em"
					}
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--base-white)",
			"text": "var(--wp--preset--color--text-main)"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--brand-yellow)",
					"text": "var(--wp--preset--color--text-main)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "3rem"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "2.25rem"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "1.75rem"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "1.5rem"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "1.25rem"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "1rem"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--pt-serif)",
					"fontStyle": "normal",
					"fontWeight": "700"
				}
			},
			"link": {
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--brand-yellow-hover)"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--brand-green)"
				}
			}
		},
		"spacing": {
			"padding": {
				"bottom": "0px",
				"left": "1rem",
				"right": "1rem",
				"top": "0px"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--open-sans)",
			"fontSize": "var(--wp--preset--font-size--small)",
			"fontStyle": "normal",
			"fontWeight": "400",
			"lineHeight": "1.5"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header"
		},
		{
			"area": "footer",
			"name": "footer"
		}
	]
}